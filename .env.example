# ── Outcome environment ──────────────────────────────────────────────────────
# Copy to `.env` and fill EVERY value. NEVER commit `.env`.
#
#   cp .env.example .env
#   # generate secrets:
#   JWT_KEY:           openssl rand -hex 32
#   POSTGRES_PASSWORD: openssl rand -hex 24
#   MINIO_ACCESS_KEY:  openssl rand -hex 12
#   MINIO_SECRET_KEY:  openssl rand -hex 24
#   MINIO_ENC_KEY:     openssl rand -base64 32
#   LIVEKIT_API_KEY:   echo "LK$(openssl rand -hex 6)"
#   LIVEKIT_API_SECRET: openssl rand -hex 24

# ── Public address ───────────────────────────────────────────────────────────
# The domain users open in the browser. Caddy auto-provisions a Let's Encrypt cert
# for it (and for www.<domain>). Point the domain's DNS A record at this host FIRST.
OUTCOME_DOMAIN=chat.example.com
# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=admin@example.com
# Public IP of THIS host — LiveKit advertises it so browsers can reach voice/video
# media directly (media bypasses the L7 proxy). Must be reachable on 7881-7882.
LIVEKIT_NODE_IP=203.0.113.10

# ── Version ──────────────────────────────────────────────────────────────────
# Image tag to run (see https://hub.docker.com/r/skayloo/outcome-server/tags).
# Pin a version for reproducible deploys; `latest` also works.
OUTCOME_TAG=1.3.1

# ── Scale ────────────────────────────────────────────────────────────────────
# API replicas. 2 is plenty to start; raise on beefier hosts.
SERVER_REPLICAS=2

# ── Secrets (GENERATE fresh values — see the commands at the top) ────────────
POSTGRES_PASSWORD=CHANGE_ME
JWT_KEY=CHANGE_ME
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
# AES-256-GCM at-rest encryption for uploaded files (base64 of 32 bytes).
# Losing this key makes previously uploaded files unreadable — back it up.
MINIO_ENC_KEY=CHANGE_ME
LIVEKIT_API_KEY=LKchangeme
LIVEKIT_API_SECRET=CHANGE_ME

# ── App settings ─────────────────────────────────────────────────────────────
SERVER_NAME=Outcome
MINIO_BUCKET=outcome-uploads

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Used for registration codes, 2FA and notifications.
# Leave EMAIL_HOST empty to run without mail — codes are then printed to the
# server log instead (fine for a first spin-up / LAN install).
#
# Option A — the bundled mail server (docker compose --profile mail, see README):
#   EMAIL_HOST=mail.<your-domain>   EMAIL_PORT=587   EMAIL_USE_SSL=false
#   EMAIL_USERNAME=no-reply@<your-domain>  + the password you set for that account
# Option B — any external SMTP provider (e.g. a mailbox at your registrar):
#   fill in whatever the provider hands you.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@example.com
EMAIL_USE_SSL=true

# ── SSO (optional) ───────────────────────────────────────────────────────────
# Leave a pair EMPTY to hide that provider's login button entirely — clients ask
# the server which providers it holds keys for and render only those.
#
# Google — console.cloud.google.com → APIs & Services → Credentials →
#   Create credentials → OAuth client ID → type "Web application".
#   Authorized redirect URI:  https://<your-domain>/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# Yandex — oauth.yandex.ru → Create app → "Web services".
#   Redirect URI:  https://<your-domain>/api/v1/auth/oauth/yandex/callback
#   Permissions:   "Access to email address" + "Access to username"
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
